<?xml version="1.0" encoding="utf-8"?>
<test>
	<head>Изучение программирования</head>
	<topics>

		<topic name="Циклы">

			<level difficulty="1">
				<q text="Что делает оператор while?" src="">
					<a right="yes">Повторяет блок кода пока условие истинно</a>
					<a right="no">Выполняется ровно один раз</a>
					<a right="no">Переходит к следующей итерации</a>
					<a right="no">Завершает выполнение программы</a>
				</q>
				<q text="Какой цикл выполнится хотя бы один раз?" src="">
					<a right="no">while</a>
					<a right="no">for</a>
					<a right="yes">do while</a>
					<a right="no">foreach</a>
				</q>
				<q text="Что делает оператор break?" src="">
					<a right="no">Пропускает текущую итерацию</a>
					<a right="yes">Завершает выполнение цикла</a>
					<a right="no">Начинает цикл заново</a>
					<a right="no">Ничего не делает</a>
				</q>
				<q text="Выберите все виды циклов в C#" src="">
					<a right="yes">for</a>
					<a right="yes">while</a>
					<a right="yes">foreach</a>
					<a right="no">repeat</a>
				</q>
				<q text="Что делает оператор continue?" src="">
					<a right="yes">Пропускает текущую итерацию</a>
					<a right="no">Завершает цикл</a>
					<a right="no">Выходит из программы</a>
					<a right="no">Начинает новый цикл</a>
				</q>
				<q text="Что выведет код: for(int i=0; i&lt;3; i++) Console.Write(i)?" src="">
					<a right="yes">012</a>
					<a right="no">123</a>
					<a right="no">0123</a>
					<a right="no">321</a>
				</q>
				<q text="Для чего используется foreach?" src="">
					<a right="yes">Перебор элементов коллекции</a>
					<a right="no">Счётный цикл с индексом</a>
					<a right="no">Бесконечный цикл</a>
					<a right="no">Цикл с постусловием</a>
				</q>
				<q text="Что такое бесконечный цикл?" src="">
					<a right="yes">Цикл условие которого всегда истинно</a>
					<a right="no">Цикл который не выполняется</a>
					<a right="no">Цикл с большим числом итераций</a>
					<a right="no">Цикл внутри цикла</a>
				</q>
				<q text="Какие операторы прерывают цикл? (выберите все)" src="">
					<a right="yes">break</a>
					<a right="no">continue</a>
					<a right="yes">return</a>
					<a right="no">skip</a>
				</q>
				<q text="Что означает i++ в цикле for?" src="">
					<a right="yes">Увеличить i на 1 после итерации</a>
					<a right="no">Уменьшить i на 1</a>
					<a right="no">Умножить i на 2</a>
					<a right="no">Обнулить i</a>
				</q>
			</level>

			<level difficulty="2">
				<q text="Чем отличается while от do while?" src="">
					<a right="yes">do while проверяет условие после выполнения тела</a>
					<a right="no">while быстрее</a>
					<a right="no">do while не поддерживает break</a>
					<a right="no">Ничем не отличаются</a>
				</q>
				<q text="Что выведет: int i=5; while(i&gt;0) { Console.Write(i); i-=2; }?" src="">
					<a right="yes">531</a>
					<a right="no">54321</a>
					<a right="no">5310</a>
					<a right="no">135</a>
				</q>
				<q text="Как называется цикл внутри цикла?" src="">
					<a right="yes">Вложенный цикл</a>
					<a right="no">Двойной цикл</a>
					<a right="no">Рекурсивный цикл</a>
					<a right="no">Параллельный цикл</a>
				</q>
				<q text="Что произойдёт если условие while изначально ложно?" src="">
					<a right="yes">Цикл не выполнится ни разу</a>
					<a right="no">Выполнится один раз</a>
					<a right="no">Будет ошибка</a>
					<a right="no">Цикл станет бесконечным</a>
				</q>

				<q text="Что делает вложенный цикл?" src="">
					<a right="yes">Выполняет один цикл внутри другого</a>
					<a right="no">Запускает цикл параллельно</a>
					<a right="no">Прерывает внешний цикл</a>
					<a right="no">Удаляет цикл</a>
				</q>

				<q text="Что произойдёт при break во внутреннем цикле?" src="">
					<a right="yes">Прервётся только внутренний цикл</a>
					<a right="no">Прервутся оба цикла</a>
					<a right="no">Программа завершится</a>
					<a right="no">Ничего не произойдёт</a>
				</q>

				<q text="Что делает continue во вложенном цикле?" src="">
					<a right="yes">Переходит к следующей итерации текущего цикла</a>
					<a right="no">Прерывает внешний цикл</a>
					<a right="no">Завершает программу</a>
					<a right="no">Вызывает ошибку</a>
				</q>

				<q text="Какой цикл лучше использовать, если известное число итераций?" src="">
					<a right="yes">for</a>
					<a right="no">while</a>
					<a right="no">do while</a>
					<a right="no">foreach</a>
				</q>

				<q text="Что делает оператор return внутри цикла?" src="">
					<a right="yes">Выходит из метода полностью</a>
					<a right="no">Прерывает только цикл</a>
					<a right="no">Переходит к следующей итерации</a>
					<a right="no">Ничего не делает</a>
				</q>

				<q text="Можно ли изменить коллекцию внутри foreach?" src="">
					<a right="yes">Нет, это приведёт к ошибке</a>
					<a right="no">Да, всегда можно</a>
					<a right="no">Только в конце цикла</a>
					<a right="no">Только при использовании break</a>
				</q>
			</level>

			<level difficulty="3">
				<q text="Какова сложность вложенного цикла n×n?" src="">
					<a right="yes">O(n²)</a>
					<a right="no">O(n)</a>
					<a right="no">O(2n)</a>
					<a right="no">O(log n)</a>
				</q>
				<q text="Что произойдёт при бесконечном цикле без break?" src="">
					<a right="yes">Программа будет выполняться бесконечно</a>
					<a right="no">Цикл завершится сам</a>
					<a right="no">Будет ошибка компиляции</a>
					<a right="no">Программа завершится</a>
				</q>

				<q text="Как оптимизировать вложенные циклы?" src="">
					<a right="yes">Уменьшить количество итераций</a>
					<a right="no">Добавить больше циклов</a>
					<a right="no">Убрать условие</a>
					<a right="no">Использовать только while</a>
				</q>

				<q text="Что такое сложность алгоритма?" src="">
					<a right="yes">Оценка количества операций в зависимости от входных данных</a>
					<a right="no">Количество строк кода</a>
					<a right="no">Размер программы</a>
					<a right="no">Скорость компиляции</a>
				</q>

				<q text="Что означает O(n)?" src="">
					<a right="yes">Линейная зависимость от размера входных данных</a>
					<a right="no">Постоянное время</a>
					<a right="no">Квадратичная сложность</a>
					<a right="no">Логарифмическая сложность</a>
				</q>

				<q text="Как работает break с метками (label)?" src="">
					<a right="yes">Позволяет выйти из вложенных циклов</a>
					<a right="no">Работает только в while</a>
					<a right="no">Не существует в C#</a>
					<a right="no">Удаляет цикл</a>
				</q>

				<q text="Что делает yield в цикле?" src="">
					<a right="yes">Позволяет возвращать значения по одному</a>
					<a right="no">Прерывает цикл</a>
					<a right="no">Создаёт новый поток</a>
					<a right="no">Удаляет элементы</a>
				</q>

				<q text="Что быстрее при переборе: for или foreach?" src="">
					<a right="yes">for (обычно быстрее для массивов)</a>
					<a right="no">foreach всегда быстрее</a>
					<a right="no">Одинаково всегда</a>
					<a right="no">Зависит только от компилятора</a>
				</q>

				<q text="Что произойдёт при изменении индекса внутри for?" src="">
					<a right="yes">Изменится логика выполнения цикла</a>
					<a right="no">Будет ошибка компиляции</a>
					<a right="no">Цикл остановится</a>
					<a right="no">Ничего не изменится</a>
				</q>

				<q text="Можно ли реализовать бесконечный цикл через for?" src="">
					<a right="yes">Да, например for(;;)</a>
					<a right="no">Нет</a>
					<a right="no">Только через while</a>
					<a right="no">Только через do while</a>
				</q>
			</level>

		</topic>

	</topics>
</test>